[node name="Label3" type="Label" parent="Main/VBoxContainer/Panel/ScrollContainer/VBoxMain/MarginContainer2" unique_id=152373659]
layout_mode = 2
text = "🛠️ How It Works 🛠️
📋 Press Scan to find unused resources.
✅ Select the resources you want to keep or delete.
📌 Use Keep to save them to the Keep List.
🗑️ Use Delete to permanently remove them.
🧹 Optionally press Clean to remove orphaned files and empty folders."

