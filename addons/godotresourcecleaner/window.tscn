[node name="Label2" type="Label" parent="Main/VBoxContainer/Panel/ScrollContainer/VBoxMain/MarginContainer" unique_id=419720540]
layout_mode = 2
text = "⚙️ Settings:
Customize the scan behavior if needed.
📌 Keep List: 
Displays resources you want to preserve. Anything here won’t show up in future scans.
🔍 Scan: 
Scans the project for unused files and resources with no known dependencies.
🧹 Clean: 
Finds and removes orphaned .import, .uid files, and empty folders."

[node name="HSeparator2" type="HSeparator" parent="Main/VBoxContainer/Panel/ScrollContainer/VBoxMain" unique_id=1282532674]
