layout_mode = 2
text = "⚠️ Use With Caution ⚠️
Deletion of files is permanent!
Always make a backup of your project before using this tool.
Even if a file has no visible dependencies, it may still be referenced.
This tool can break your project. Use at your own risk!"
horizontal_alignment = 1

